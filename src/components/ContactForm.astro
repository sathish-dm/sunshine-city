---
// ContactForm - Submits via Web3Forms (free, no backend needed)
// Get your access key at https://web3forms.com — enter your email, they send you the key.
// Replace YOUR_ACCESS_KEY_HERE below with your actual key.
---

<form
  id="contact-form"
  action="https://api.web3forms.com/submit"
  method="POST"
  class="mx-auto max-w-3xl rounded-2xl border border-gray-100 bg-white p-6 shadow-lg sm:p-8 dark:border-gray-700 dark:bg-gray-800"
>
  <!-- Web3Forms access key -->
  <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />

  <!-- Honeypot spam protection -->
  <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

  <!-- Form name for email subject -->
  <input type="hidden" name="from_name" value="SRWA Website Contact Form" />
  <input type="hidden" name="subject" value="New message from SRWA website" />

  <!-- Redirect back after submission -->
  <input type="hidden" name="redirect" value="" id="form-redirect" />

  <h2 class="font-heading text-2xl font-bold text-text dark:text-white">
    Get in Touch
  </h2>
  <p class="mt-1 text-sm text-text-muted dark:text-gray-400">
    Have a complaint, suggestion, or query? Fill out the form below and we'll get back to you.
  </p>

  <!-- Success message (hidden by default) -->
  <div id="form-success" class="mt-6 hidden rounded-lg border border-green-200 bg-green-50 p-4 dark:border-green-800 dark:bg-green-900/20">
    <div class="flex items-center gap-3">
      <svg class="h-6 w-6 shrink-0 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <p class="font-semibold text-green-800 dark:text-green-300">Message sent successfully!</p>
        <p class="text-sm text-green-600 dark:text-green-400">We'll get back to you within 24-48 hours.</p>
      </div>
    </div>
  </div>

  <!-- Error message (hidden by default) -->
  <div id="form-error" class="mt-6 hidden rounded-lg border border-red-200 bg-red-50 p-4 dark:border-red-800 dark:bg-red-900/20">
    <div class="flex items-center gap-3">
      <svg class="h-6 w-6 shrink-0 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <p class="font-semibold text-red-800 dark:text-red-300">Something went wrong</p>
        <p class="text-sm text-red-600 dark:text-red-400">Please try again or email us at srwa.spotlight@gmail.com.</p>
      </div>
    </div>
  </div>

  <div id="form-fields" class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2">
    <!-- Name -->
    <div>
      <label for="contact-name" class="mb-1.5 block text-sm font-medium text-text dark:text-gray-200">
        Name <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="contact-name"
        name="name"
        required
        placeholder="Your full name"
        class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-text placeholder-text-muted transition-colors duration-200 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:placeholder-gray-500 dark:focus:border-primary-light dark:focus:ring-primary-light/30"
      />
    </div>

    <!-- Email -->
    <div>
      <label for="contact-email" class="mb-1.5 block text-sm font-medium text-text dark:text-gray-200">
        Email <span class="text-red-500">*</span>
      </label>
      <input
        type="email"
        id="contact-email"
        name="email"
        required
        placeholder="you@example.com"
        class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-text placeholder-text-muted transition-colors duration-200 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:placeholder-gray-500 dark:focus:border-primary-light dark:focus:ring-primary-light/30"
      />
    </div>

    <!-- Phone -->
    <div>
      <label for="contact-phone" class="mb-1.5 block text-sm font-medium text-text dark:text-gray-200">
        Phone
      </label>
      <input
        type="tel"
        id="contact-phone"
        name="phone"
        placeholder="+91 98765 43210"
        class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-text placeholder-text-muted transition-colors duration-200 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:placeholder-gray-500 dark:focus:border-primary-light dark:focus:ring-primary-light/30"
      />
    </div>

    <!-- Subject -->
    <div>
      <label for="contact-subject" class="mb-1.5 block text-sm font-medium text-text dark:text-gray-200">
        Subject <span class="text-red-500">*</span>
      </label>
      <select
        id="contact-subject"
        name="subject"
        required
        class="w-full appearance-none rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-text transition-colors duration-200 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:focus:border-primary-light dark:focus:ring-primary-light/30"
      >
        <option value="" disabled selected>Select a topic</option>
        <option value="Complaint">Complaint</option>
        <option value="Suggestion">Suggestion</option>
        <option value="Query">Query</option>
        <option value="Other">Other</option>
      </select>
    </div>

    <!-- Message -->
    <div class="sm:col-span-2">
      <label for="contact-message" class="mb-1.5 block text-sm font-medium text-text dark:text-gray-200">
        Message <span class="text-red-500">*</span>
      </label>
      <textarea
        id="contact-message"
        name="message"
        required
        rows="5"
        placeholder="Describe your complaint, suggestion, or query in detail..."
        class="w-full resize-y rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-text placeholder-text-muted transition-colors duration-200 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:placeholder-gray-500 dark:focus:border-primary-light dark:focus:ring-primary-light/30"
      ></textarea>
    </div>
  </div>

  <!-- Submit -->
  <div id="form-submit" class="mt-8">
    <button
      type="submit"
      id="submit-btn"
      class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-primary px-6 py-3 text-base font-semibold text-white shadow-sm transition-all duration-200 hover:bg-primary-dark hover:shadow-md focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 sm:w-auto dark:hover:bg-primary-light dark:focus:ring-offset-gray-800"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"/>
      </svg>
      <span id="submit-text">Submit</span>
    </button>
  </div>
</form>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const submitText = document.getElementById("submit-text") as HTMLSpanElement;
  const successMsg = document.getElementById("form-success") as HTMLDivElement;
  const errorMsg = document.getElementById("form-error") as HTMLDivElement;
  const formFields = document.getElementById("form-fields") as HTMLDivElement;
  const formSubmit = document.getElementById("form-submit") as HTMLDivElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Hide previous messages
    successMsg?.classList.add("hidden");
    errorMsg?.classList.add("hidden");

    // Show loading state
    submitBtn.disabled = true;
    submitText.textContent = "Sending...";

    try {
      const formData = new FormData(form);
      const response = await fetch(form.action, {
        method: "POST",
        body: formData,
      });

      const result = await response.json();

      if (result.success) {
        successMsg?.classList.remove("hidden");
        formFields?.classList.add("hidden");
        formSubmit?.classList.add("hidden");
        form.reset();
      } else {
        errorMsg?.classList.remove("hidden");
      }
    } catch {
      errorMsg?.classList.remove("hidden");
    } finally {
      submitBtn.disabled = false;
      submitText.textContent = "Submit";
    }
  });
</script>
