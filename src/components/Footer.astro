---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const quickLinks = [
  { name: "Home", href: `${base}/` },
  { name: "About", href: `${base}/about` },
  { name: "Committee", href: `${base}/committee` },
  { name: "Events", href: `${base}/events` },
  { name: "Documents", href: `${base}/documents` },
  { name: "Gallery", href: `${base}/gallery` },
  { name: "Residents", href: `${base}/residents` },
  { name: "Contact", href: `${base}/contact` },
];
---

<footer class="bg-primary-dark text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- About SRWA -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <img src={`${base}/favicon.svg`} alt="SRWA Logo" class="h-8 w-8" />
          <span class="font-heading text-xl font-bold tracking-wide">SRWA</span>
        </div>
        <p class="text-white/70 text-sm leading-relaxed">
          Sunshine Residents Welfare Association - Building a vibrant, connected, and thriving community for all residents of Sunshine City, Thirumazhisai.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-heading text-lg font-semibold mb-4 text-secondary">Quick Links</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-white/70 hover:text-secondary-light text-sm transition-colors duration-200"
              >
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="font-heading text-lg font-semibold mb-4 text-secondary">Contact Us</h3>
        <ul class="space-y-3 text-sm text-white/70">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 mt-0.5 shrink-0 text-secondary-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Sunshine City, Thirumazhisai,<br />Chennai - 602107</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 shrink-0 text-secondary-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:srwa.spotlight@gmail.com" class="hover:text-secondary-light transition-colors duration-200">
              srwa.spotlight@gmail.com
            </a>
          </li>
        </ul>
      </div>

      <!-- Connect With Us -->
      <div>
        <h3 class="font-heading text-lg font-semibold mb-4 text-secondary">Connect With Us</h3>
        <p class="text-white/70 text-sm mb-4">
          Stay updated with the latest announcements and events in our community.
        </p>
        <a
          href={`${base}/contact`}
          class="inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Contact Us
        </a>
      </div>
    </div>

    <!-- Divider and Copyright -->
    <div class="mt-10 pt-6 border-t border-white/10 text-center">
      <p class="text-white/50 text-sm">
        &copy; 2026 SRWA - Sunshine Residents Welfare Association. All rights reserved.
      </p>
    </div>
  </div>
</footer>
