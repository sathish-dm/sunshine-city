---
interface Props {
  title: string;
  date: string;
  category?: string;
  description?: string;
  important?: boolean;
}

const {
  title,
  date,
  category,
  description,
  important = false,
} = Astro.props;

const dateObj = new Date(date);
const formattedDate = dateObj.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<div
  class:list={[
    "rounded-2xl border p-5 shadow-md transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg",
    important
      ? "border-l-4 border-l-secondary border-t-gray-100 border-r-gray-100 border-b-gray-100 bg-secondary/5 dark:border-l-secondary-light dark:border-t-gray-700 dark:border-r-gray-700 dark:border-b-gray-700 dark:bg-secondary/10"
      : "border-gray-100 bg-white dark:border-gray-700 dark:bg-gray-800",
  ]}
>
  <!-- Header -->
  <div class="mb-3 flex flex-wrap items-start justify-between gap-2">
    <div class="flex flex-wrap items-center gap-2">
      {important && (
        <span class="inline-flex items-center gap-1 rounded-full bg-secondary/15 px-2.5 py-0.5 text-xs font-semibold text-secondary dark:bg-secondary/25 dark:text-secondary-light">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
          </svg>
          Important
        </span>
      )}
      {category && (
        <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary dark:bg-primary/20 dark:text-primary-light">
          {category}
        </span>
      )}
    </div>
    <time class="text-xs text-text-muted dark:text-gray-500" datetime={date}>
      {formattedDate}
    </time>
  </div>

  <!-- Title -->
  <h3 class="font-heading text-lg font-semibold text-text dark:text-white">
    {title}
  </h3>

  <!-- Description -->
  {description && (
    <p class="mt-2 text-sm leading-relaxed text-text-light dark:text-gray-400">
      {description}
    </p>
  )}
</div>
