---
interface Props {
  name: string;
  position: string;
  image?: string;
}

const { name, position, image } = Astro.props;
---

<div class="group rounded-2xl border border-gray-100 bg-white p-6 shadow-md transition-all duration-300 hover:-translate-y-1 hover:shadow-xl dark:border-gray-700 dark:bg-gray-800">
  <div class="flex flex-col items-center text-center">
    <!-- Avatar -->
    <div class="relative mb-4">
      {image ? (
        <img
          src={image}
          alt={name}
          class="h-24 w-24 rounded-full border-4 border-primary-light object-cover shadow-sm dark:border-primary"
          loading="lazy"
        />
      ) : (
        <div class="flex h-24 w-24 items-center justify-center rounded-full border-4 border-primary-light bg-primary/10 text-2xl font-bold text-primary dark:border-primary dark:bg-primary/20">
          {name.split(" ").map((n) => n[0]).join("").slice(0, 2)}
        </div>
      )}
    </div>

    <!-- Info -->
    <h3 class="font-heading text-lg font-semibold text-text dark:text-white">
      {name}
    </h3>
    <p class="mt-1 text-sm font-medium text-primary dark:text-primary-light">
      {position}
    </p>
  </div>
</div>
