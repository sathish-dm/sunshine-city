---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found">
  <section class="flex min-h-[60vh] items-center justify-center px-4 py-20">
    <div class="text-center">
      <h1 class="font-heading text-8xl font-bold text-primary sm:text-9xl dark:text-primary-light">
        404
      </h1>
      <h2 class="mt-4 font-heading text-2xl font-semibold text-text sm:text-3xl dark:text-white">
        Page Not Found
      </h2>
      <p class="mt-3 text-lg text-text-muted dark:text-gray-400">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 font-semibold text-white transition-colors hover:bg-primary-dark"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        Back to Home
      </a>
    </div>
  </section>
</BaseLayout>
