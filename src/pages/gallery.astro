---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const photos = [
  { id: 1, caption: "Annual Sports Day 2025", category: "Events", color: "bg-primary" },
  { id: 2, caption: "Cricket Tournament Finals", category: "Sports", color: "bg-secondary" },
  { id: 3, caption: "Pongal Celebration 2026", category: "Festivals", color: "bg-amber-500 dark:bg-amber-600" },
  { id: 4, caption: "Community Clean-up Drive", category: "Community", color: "bg-emerald-500 dark:bg-emerald-600" },
  { id: 5, caption: "Independence Day Flag Hoisting", category: "Events", color: "bg-primary-dark" },
  { id: 6, caption: "Badminton Championship", category: "Sports", color: "bg-secondary-dark" },
  { id: 7, caption: "Deepavali Celebration", category: "Festivals", color: "bg-orange-500 dark:bg-orange-600" },
  { id: 8, caption: "Tree Plantation Drive", category: "Community", color: "bg-green-600 dark:bg-green-700" },
  { id: 9, caption: "Republic Day Parade", category: "Events", color: "bg-primary-light" },
  { id: 10, caption: "Kids Football Match", category: "Sports", color: "bg-secondary-light" },
  { id: 11, caption: "Christmas Carol Night", category: "Festivals", color: "bg-rose-500 dark:bg-rose-600" },
  { id: 12, caption: "Residents Get-together", category: "Community", color: "bg-teal-500 dark:bg-teal-600" },
];

const filterCategories = ["All", "Events", "Sports", "Festivals", "Community"];
---

<BaseLayout title="Gallery - SRWA" description="Browse photos from community events, sports, festivals, and activities at Sunshine City.">
  <!-- Page Header Banner -->
  <section class="relative bg-gradient-to-br from-primary-dark to-primary py-16 sm:py-20">
    <div class="absolute inset-0 opacity-10" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.4'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"></div>
    <div class="relative z-10 mx-auto max-w-5xl px-4 text-center sm:px-6">
      <h1 class="font-heading text-4xl font-bold text-white sm:text-5xl">Photo Gallery</h1>
      <p class="mt-3 text-lg text-white/80">Moments captured from our vibrant community</p>
      <nav class="mt-4 flex items-center justify-center gap-2 text-sm text-white/70">
        <a href={`${base}/`} class="transition-colors hover:text-white">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
        </svg>
        <span class="text-white">Gallery</span>
      </nav>
    </div>
  </section>

  <!-- Filter & Gallery -->
  <section class="bg-bg py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <!-- Category Filter Buttons -->
      <div class="mb-10 flex flex-wrap items-center justify-center gap-3" id="gallery-filters">
        {filterCategories.map((cat) => (
          <button
            data-filter={cat.toLowerCase()}
            class:list={[
              "gallery-filter-btn rounded-full px-5 py-2 text-sm font-medium transition-all duration-300",
              cat === "All"
                ? "bg-primary text-white shadow-md"
                : "bg-white text-text-light border border-gray-200 hover:border-primary hover:text-primary dark:bg-gray-800 dark:text-gray-300 dark:border-gray-700 dark:hover:border-primary-light dark:hover:text-primary-light",
            ]}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Photo Grid -->
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4" id="gallery-grid">
        {photos.map((photo) => (
          <div
            class="gallery-item group cursor-pointer"
            data-category={photo.category.toLowerCase()}
            data-caption={photo.caption}
          >
            <div class="overflow-hidden rounded-xl border border-gray-100 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg dark:border-gray-700 dark:bg-gray-800">
              <!-- Placeholder Image -->
              <div class={`relative flex h-48 items-center justify-center ${photo.color}`}>
                <div class="text-center text-white/80">
                  <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"/>
                  </svg>
                  <span class="mt-2 block text-xs font-medium uppercase tracking-wider">{photo.category}</span>
                </div>
                <!-- Hover overlay -->
                <div class="absolute inset-0 flex items-center justify-center bg-black/0 transition-all duration-300 group-hover:bg-black/30">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white opacity-0 transition-opacity duration-300 group-hover:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6"/>
                  </svg>
                </div>
              </div>
              <!-- Caption -->
              <div class="p-4">
                <p class="text-sm font-medium text-text dark:text-white">{photo.caption}</p>
                <span class="mt-1 inline-block text-xs text-text-muted dark:text-gray-400">{photo.category}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 p-4 backdrop-blur-sm">
    <button id="lightbox-close" class="absolute right-4 top-4 flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white transition-colors hover:bg-white/20">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    <div class="max-h-[80vh] w-full max-w-3xl overflow-hidden rounded-2xl bg-white shadow-2xl dark:bg-gray-800">
      <div id="lightbox-image" class="flex h-72 items-center justify-center bg-primary sm:h-96">
        <div class="text-center text-white/80">
          <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"/>
          </svg>
          <span id="lightbox-category-label" class="mt-2 block text-sm font-medium uppercase tracking-wider"></span>
        </div>
      </div>
      <div class="p-5">
        <p id="lightbox-caption" class="font-heading text-lg font-semibold text-text dark:text-white"></p>
        <span id="lightbox-category" class="mt-1 inline-block text-sm text-text-muted dark:text-gray-400"></span>
      </div>
    </div>
  </div>

  <!-- Note -->
  <section class="bg-bg-alt py-12 sm:py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="rounded-2xl border border-gray-100 bg-white p-6 text-center shadow-sm sm:p-8 dark:border-gray-700 dark:bg-gray-800">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"/>
          </svg>
        </div>
        <p class="mt-4 text-lg font-medium text-text dark:text-white">More photos coming soon!</p>
        <p class="mt-1 text-text-muted dark:text-gray-400">Share your community photos with us.</p>
      </div>
    </div>
  </section>

  <!-- Gallery Scripts -->
  <script is:inline>
    // Category filter
    document.querySelectorAll('.gallery-filter-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var filter = btn.getAttribute('data-filter');

        // Update active button styling
        document.querySelectorAll('.gallery-filter-btn').forEach(function(b) {
          b.classList.remove('bg-primary', 'text-white', 'shadow-md');
          b.classList.add('bg-white', 'text-text-light', 'border', 'border-gray-200', 'hover:border-primary', 'hover:text-primary', 'dark:bg-gray-800', 'dark:text-gray-300', 'dark:border-gray-700', 'dark:hover:border-primary-light', 'dark:hover:text-primary-light');
        });
        btn.classList.remove('bg-white', 'text-text-light', 'border', 'border-gray-200', 'hover:border-primary', 'hover:text-primary', 'dark:bg-gray-800', 'dark:text-gray-300', 'dark:border-gray-700', 'dark:hover:border-primary-light', 'dark:hover:text-primary-light');
        btn.classList.add('bg-primary', 'text-white', 'shadow-md');

        // Filter items
        document.querySelectorAll('.gallery-item').forEach(function(item) {
          if (filter === 'all' || item.getAttribute('data-category') === filter) {
            item.style.display = '';
          } else {
            item.style.display = 'none';
          }
        });
      });
    });

    // Lightbox
    var lightbox = document.getElementById('lightbox');
    var lightboxImage = document.getElementById('lightbox-image');
    var lightboxCaption = document.getElementById('lightbox-caption');
    var lightboxCategory = document.getElementById('lightbox-category');
    var lightboxCategoryLabel = document.getElementById('lightbox-category-label');
    var lightboxClose = document.getElementById('lightbox-close');

    document.querySelectorAll('.gallery-item').forEach(function(item) {
      item.addEventListener('click', function() {
        var caption = item.getAttribute('data-caption');
        var category = item.querySelector('.p-4 .text-xs').textContent;
        var placeholder = item.querySelector('.relative');

        // Copy background color classes to lightbox image area
        var allClasses = Array.from(placeholder.classList);
        // Reset lightbox-image classes
        lightboxImage.className = 'flex h-72 sm:h-96 items-center justify-center';
        allClasses.forEach(function(c) {
          if (c.indexOf('bg-') === 0) {
            lightboxImage.classList.add(c);
          }
        });

        lightboxCaption.textContent = caption;
        lightboxCategory.textContent = category;
        lightboxCategoryLabel.textContent = category;

        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
      });
    });

    function closeLightbox() {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
    }

    lightboxClose.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', function(e) {
      if (e.target === lightbox) closeLightbox();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeLightbox();
    });
  </script>
</BaseLayout>
