---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const categories = [
  {
    name: "Association Rules",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>`,
    documents: [
      { name: "SRWA Bylaws & Rules", size: "245 KB", file: "srwa-bylaws-rules.pdf" },
      { name: "Community Guidelines", size: "180 KB", file: "community-guidelines.pdf" },
    ],
  },
  {
    name: "Building Guidelines",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21"/></svg>`,
    documents: [
      { name: "Construction Guidelines", size: "320 KB", file: "construction-guidelines.pdf" },
      { name: "Elevation Standards", size: "410 KB", file: "elevation-standards.pdf" },
    ],
  },
  {
    name: "Meeting Minutes",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>`,
    documents: [
      { name: "AGM Minutes 2025", size: "156 KB", file: "agm-minutes-2025.pdf" },
      { name: "Committee Meeting - Feb 2026", size: "98 KB", file: "committee-meeting-feb-2026.pdf" },
    ],
  },
  {
    name: "Forms",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/></svg>`,
    documents: [
      { name: "Membership Application Form", size: "120 KB", file: "membership-application-form.pdf" },
      { name: "Complaint Form", size: "85 KB", file: "complaint-form.pdf" },
      { name: "NOC Request Form", size: "92 KB", file: "noc-request-form.pdf" },
    ],
  },
];
---

<BaseLayout title="Documents - SRWA" description="Access and download important community documents, forms, and meeting minutes from SRWA.">
  <!-- Page Header Banner -->
  <section class="relative bg-gradient-to-br from-primary-dark to-primary py-16 sm:py-20">
    <div class="absolute inset-0 opacity-10" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.4'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"></div>
    <div class="relative z-10 mx-auto max-w-5xl px-4 text-center sm:px-6">
      <h1 class="font-heading text-4xl font-bold text-white sm:text-5xl">Documents & Downloads</h1>
      <p class="mt-3 text-lg text-white/80">Access important community documents</p>
      <nav class="mt-4 flex items-center justify-center gap-2 text-sm text-white/70">
        <a href={`${base}/`} class="transition-colors hover:text-white">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
        </svg>
        <span class="text-white">Documents</span>
      </nav>
    </div>
  </section>

  <!-- Documents List -->
  <section class="bg-bg py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="space-y-12">
        {categories.map((category) => (
          <div>
            <!-- Category Header -->
            <div class="flex items-center gap-3 mb-6">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light">
                <Fragment set:html={category.icon} />
              </div>
              <h2 class="font-heading text-2xl font-bold text-text dark:text-white">{category.name}</h2>
            </div>

            <!-- Document Cards -->
            <div class="grid gap-4 sm:grid-cols-2">
              {category.documents.map((doc) => (
                <div class="group flex items-center gap-4 rounded-xl border border-gray-100 bg-white p-5 shadow-sm transition-all duration-300 hover:shadow-md dark:border-gray-700 dark:bg-gray-800">
                  <!-- PDF Icon -->
                  <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-red-50 text-red-500 dark:bg-red-900/20 dark:text-red-400">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m.75 12l3 3m0 0l3-3m-3 3v-6m-1.5-9H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                    </svg>
                  </div>

                  <!-- Document Info -->
                  <div class="flex-1 min-w-0">
                    <h3 class="font-medium text-text dark:text-white truncate">{doc.name}</h3>
                    <div class="mt-1 flex items-center gap-3 text-sm text-text-muted dark:text-gray-400">
                      <span class="inline-flex items-center gap-1 rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-600 dark:bg-red-900/20 dark:text-red-400">
                        PDF
                      </span>
                      <span>{doc.size}</span>
                    </div>
                  </div>

                  <!-- Download Link -->
                  <a
                    href={`${base}/documents/${doc.file}`}
                    class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary transition-colors hover:bg-primary hover:text-white dark:bg-primary/20 dark:text-primary-light dark:hover:bg-primary dark:hover:text-white"
                    title={`Download ${doc.name}`}
                    download
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
                    </svg>
                  </a>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Notice -->
  <section class="bg-bg-alt py-12 sm:py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="rounded-2xl border border-amber-200 bg-amber-50 p-6 sm:p-8 dark:border-amber-800 dark:bg-amber-900/20">
        <div class="flex items-start gap-4">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-amber-100 text-amber-600 dark:bg-amber-900/40 dark:text-amber-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-heading text-lg font-semibold text-amber-800 dark:text-amber-300">Please Note</h3>
            <p class="mt-1 text-amber-700 dark:text-amber-400/80">
              Documents will be uploaded soon. Contact the association office for any document requests.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
