---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import EventCard from "../components/EventCard.astro";

import events from "../data/events.json";

const upcomingEvents = events.filter((e) => e.status === "upcoming").slice(0, 2);

const quickLinks = [
  {
    title: "About Us",
    href: "/about",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    description: "Learn about our community",
  },
  {
    title: "Committee",
    href: "/committee",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
    description: "Meet your committee members",
  },
  {
    title: "Documents",
    href: "/documents",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
    description: "Access community documents",
  },
  {
    title: "Gallery",
    href: "/gallery",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
    description: "View community photos",
  },
  {
    title: "Residents Corner",
    href: "/residents",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
    description: "Community resources & info",
  },
  {
    title: "Contact Us",
    href: "/contact",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    description: "Get in touch with SRWA",
  },
];

const emergencyNumbers = [
  { label: "Police", number: "100", color: "bg-blue-600" },
  { label: "Fire", number: "101", color: "bg-red-600" },
  { label: "Ambulance", number: "108", color: "bg-green-600" },
  { label: "Women Helpline", number: "181", color: "bg-purple-600" },
];
---

<BaseLayout title="SRWA - Sunshine Residents Welfare Association">
  <!-- Hero -->
  <Hero showStats={true} />

  <!-- Welcome Section -->
  <section class="bg-bg py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="text-center">
        <h2 class="font-heading text-3xl font-bold text-text sm:text-4xl dark:text-white">
          Welcome to Our Community
        </h2>
        <div class="mx-auto mt-2 h-1 w-20 rounded-full bg-primary"></div>
      </div>
      <div class="animate-on-scroll mt-10 rounded-2xl border border-gray-100 bg-white p-8 shadow-lg sm:p-10 dark:border-gray-700 dark:bg-gray-800">
        <div class="flex flex-col items-center gap-6 sm:flex-row sm:items-start">
          <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
          </div>
          <div>
            <p class="text-lg leading-relaxed text-text-light dark:text-gray-300">
              Dear Residents, it is my pleasure to welcome you to the Sunshine City community. As President of the Sunshine Residents Welfare Association, I am proud to lead an association that is committed to building a harmonious, safe, and thriving neighbourhood for every family here. Our community of 599 plots spread across 36 beautiful acres is more than just a residential layout -- it is a place we all call home. Together, let us continue to foster a spirit of cooperation, celebrate our diversity, and work towards making Sunshine City the finest community in Thirumazhisai.
            </p>
            <p class="mt-4 font-heading text-lg font-semibold text-primary dark:text-primary-light">
              Mr. Lakshmi Narayanan
            </p>
            <p class="text-sm text-text-muted dark:text-gray-500">President, SRWA</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Upcoming Events -->
  <section class="bg-bg py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="animate-on-scroll flex flex-col items-center justify-between gap-4 sm:flex-row">
        <div>
          <h2 class="font-heading text-3xl font-bold text-text sm:text-4xl dark:text-white">
            Upcoming Events
          </h2>
          <p class="mt-2 text-text-muted dark:text-gray-400">Join us at our next community events</p>
        </div>
        <a
          href="/events"
          class="inline-flex items-center gap-1.5 rounded-full border border-primary px-5 py-2.5 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white dark:border-primary-light dark:text-primary-light dark:hover:bg-primary-light dark:hover:text-white"
        >
          View All
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>
      <div class="mt-8 grid gap-6 sm:grid-cols-1 lg:grid-cols-2">
        {upcomingEvents.map((e) => (
          <EventCard
            title={e.title}
            date={e.date}
            time={e.time}
            location={e.location}
            category={e.category}
            description={e.description}
            status={e.status as "upcoming" | "past"}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="bg-bg-alt py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="text-center">
        <h2 class="font-heading text-3xl font-bold text-text sm:text-4xl dark:text-white">
          Quick Links
        </h2>
        <p class="mt-2 text-text-muted dark:text-gray-400">Navigate to key sections of our website</p>
      </div>
      <div class="animate-on-scroll mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {quickLinks.map((link) => (
          <a
            href={link.href}
            class="group flex flex-col items-center rounded-2xl border border-gray-100 bg-white p-6 text-center shadow-md transition-all duration-300 hover:-translate-y-1 hover:shadow-xl dark:border-gray-700 dark:bg-gray-800"
          >
            <div class="flex h-16 w-16 items-center justify-center rounded-full bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-white dark:bg-primary/20 dark:text-primary-light dark:group-hover:bg-primary dark:group-hover:text-white">
              <Fragment set:html={link.icon} />
            </div>
            <h3 class="mt-4 font-heading text-lg font-semibold text-text dark:text-white">
              {link.title}
            </h3>
            <p class="mt-1 text-sm text-text-muted dark:text-gray-400">
              {link.description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Members Portal Coming Soon -->
  <section class="bg-gradient-to-r from-primary to-primary-dark py-12 sm:py-16">
    <div class="mx-auto max-w-5xl px-4 text-center sm:px-6">
      <div class="inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-1.5 text-sm font-medium text-white backdrop-blur-sm">
        <span class="h-2 w-2 animate-pulse rounded-full bg-secondary"></span>
        Coming Soon
      </div>
      <h2 class="mt-4 font-heading text-3xl font-bold text-white sm:text-4xl">
        Members Portal
      </h2>
      <p class="mx-auto mt-3 max-w-2xl text-lg text-white/80">
        A dedicated portal for residents to manage dues, raise complaints, book community facilities, and stay connected. Stay tuned for updates!
      </p>
    </div>
  </section>

  <!-- Emergency SOS -->
  <section class="bg-bg py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="animate-on-scroll rounded-2xl border border-red-200 bg-red-50 p-8 sm:p-10 dark:border-red-900/50 dark:bg-red-950/20">
        <div class="text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-red-100 dark:bg-red-900/40">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <h2 class="mt-4 font-heading text-3xl font-bold text-red-800 sm:text-4xl dark:text-red-300">
            Emergency SOS
          </h2>
          <p class="mt-2 text-red-600 dark:text-red-400">Important emergency numbers for quick access</p>
        </div>
        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {emergencyNumbers.map((item) => (
            <div class="flex flex-col items-center rounded-xl bg-white p-5 shadow-sm dark:bg-gray-800">
              <span class={`inline-flex h-12 w-12 items-center justify-center rounded-full text-white ${item.color}`}>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </span>
              <p class="mt-3 text-sm font-medium text-text-muted dark:text-gray-400">{item.label}</p>
              <p class="mt-1 font-heading text-2xl font-bold text-text dark:text-white">{item.number}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
