---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const objectives = [
  "Promote harmony and a sense of belonging among all residents",
  "Maintain and continuously improve community facilities and infrastructure",
  "Coordinate with the local Panchayat for civic services and public amenities",
  "Oversee security and safety measures across the layout",
  "Organize cultural, social, and recreational events throughout the year",
];

const highlights = [
  {
    title: "5 Landscaped Parks",
    description: "Beautifully maintained green spaces for leisure and recreation",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>`,
  },
  {
    title: "60ft Wide Roads",
    description: "Spacious, well-paved roads for safe and comfortable commuting",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>`,
  },
  {
    title: "24/7 Water Supply",
    description: "Reliable round-the-clock water supply for all residents",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3c-4.97 4.97-7 8.03-7 11a7 7 0 1014 0c0-2.97-2.03-6.03-7-11z"/></svg>`,
  },
  {
    title: "Community Security",
    description: "Security measures with CCTV surveillance at key points",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
  },
  {
    title: "Underground Drainage",
    description: "Modern underground drainage system for a clean environment",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>`,
  },
  {
    title: "Street Lighting",
    description: "Well-lit streets and common areas for safety after dark",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
  },
];
---

<BaseLayout title="About Us - SRWA" description="Learn about Sunshine City - a 36-acre RERA-approved residential community layout in Thirumazhisai, Chennai with 599 residential plots.">
  <!-- Page Header Banner -->
  <section class="relative bg-gradient-to-br from-primary-dark to-primary py-16 sm:py-20">
    <div class="absolute inset-0 opacity-10" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.4'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"></div>
    <div class="relative z-10 mx-auto max-w-5xl px-4 text-center sm:px-6">
      <h1 class="font-heading text-4xl font-bold text-white sm:text-5xl">About Us</h1>
      <nav class="mt-4 flex items-center justify-center gap-2 text-sm text-white/70">
        <a href={`${base}/`} class="transition-colors hover:text-white">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
        </svg>
        <span class="text-white">About Us</span>
      </nav>
    </div>
  </section>

  <!-- Association Introduction -->
  <section class="bg-bg py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="text-center">
        <h2 class="font-heading text-3xl font-bold text-text sm:text-4xl dark:text-white">
          Our Community
        </h2>
        <div class="mx-auto mt-2 h-1 w-20 rounded-full bg-primary"></div>
      </div>
      <div class="mt-10 rounded-2xl border border-gray-100 bg-white p-8 shadow-lg sm:p-10 dark:border-gray-700 dark:bg-gray-800">
        <p class="text-lg leading-relaxed text-text-light dark:text-gray-300">
          Sunshine City is a prestigious <strong class="text-text dark:text-white">36-acre RERA-approved residential community layout</strong> developed by <strong class="text-text dark:text-white">Ramky Wavoo Developers</strong>, located in the rapidly growing locality of <strong class="text-text dark:text-white">Thirumazhisai, Chennai</strong>. The layout comprises <strong class="text-text dark:text-white">599 residential plots</strong> with modern infrastructure including wide internal roads, underground drainage, round-the-clock water supply, landscaped parks, and 24/7 security.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-text-light dark:text-gray-300">
          The Sunshine Residents Welfare Association (SRWA) was formed by the residents to ensure the upkeep, governance, and betterment of this community. The association works closely with residents, the developer, and local authorities to maintain the highest standards of living within the layout.
        </p>
      </div>
    </div>
  </section>

  <!-- Vision & Mission -->
  <section class="bg-bg-alt py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="text-center">
        <h2 class="font-heading text-3xl font-bold text-text sm:text-4xl dark:text-white">
          Vision & Mission
        </h2>
        <div class="mx-auto mt-2 h-1 w-20 rounded-full bg-primary"></div>
      </div>
      <div class="mt-10 grid gap-8 sm:grid-cols-2">
        <!-- Vision Card -->
        <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-lg dark:border-gray-700 dark:bg-gray-800">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
          </div>
          <h3 class="mt-5 font-heading text-2xl font-bold text-text dark:text-white">Our Vision</h3>
          <p class="mt-3 text-lg leading-relaxed text-text-light dark:text-gray-300">
            To build a vibrant, safe, and sustainable residential community where every family thrives.
          </p>
        </div>

        <!-- Mission Card -->
        <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-lg dark:border-gray-700 dark:bg-gray-800">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-secondary/10 text-secondary dark:bg-secondary/20 dark:text-secondary-light">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="mt-5 font-heading text-2xl font-bold text-text dark:text-white">Our Mission</h3>
          <p class="mt-3 text-lg leading-relaxed text-text-light dark:text-gray-300">
            To ensure world-class infrastructure, foster harmonious living, and maintain transparent governance for all residents of Sunshine City.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Objectives -->
  <section class="bg-bg py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="text-center">
        <h2 class="font-heading text-3xl font-bold text-text sm:text-4xl dark:text-white">
          Our Objectives
        </h2>
        <div class="mx-auto mt-2 h-1 w-20 rounded-full bg-primary"></div>
        <p class="mt-4 text-text-muted dark:text-gray-400">What we strive to achieve for our community</p>
      </div>
      <div class="mt-10 space-y-4">
        {objectives.map((objective, index) => (
          <div class="flex items-start gap-4 rounded-xl border border-gray-100 bg-white p-5 shadow-sm transition-all duration-300 hover:shadow-md dark:border-gray-700 dark:bg-gray-800">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">
              {index + 1}
            </span>
            <p class="pt-1.5 text-lg text-text-light dark:text-gray-300">
              {objective}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Community Highlights -->
  <section class="bg-bg-alt py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="text-center">
        <h2 class="font-heading text-3xl font-bold text-text sm:text-4xl dark:text-white">
          Community Highlights
        </h2>
        <div class="mx-auto mt-2 h-1 w-20 rounded-full bg-primary"></div>
        <p class="mt-4 text-text-muted dark:text-gray-400">Modern amenities that make Sunshine City stand out</p>
      </div>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {highlights.map((item) => (
          <div class="group rounded-2xl border border-gray-100 bg-white p-6 text-center shadow-md transition-all duration-300 hover:-translate-y-1 hover:shadow-xl dark:border-gray-700 dark:bg-gray-800">
            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-white dark:bg-primary/20 dark:text-primary-light dark:group-hover:bg-primary dark:group-hover:text-white">
              <Fragment set:html={item.icon} />
            </div>
            <h3 class="mt-4 font-heading text-lg font-semibold text-text dark:text-white">
              {item.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-text-muted dark:text-gray-400">
              {item.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
